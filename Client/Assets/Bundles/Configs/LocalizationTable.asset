  - EntryId: 34249437
    SectionId: 74957667
    Key: UI.Shop.Category.Recommend.Description
    Value: "\u0420\u043E\u0442\u0430\u0446\u0438\u044F \u0442\u043E\u0432\u0430\u0440\u043E\u0432
      \u0438\u0437 \u0440\u0430\u0437\u043D\u044B\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432
      \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0430.\n\n\u041F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0439\u0442\u0435
      \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0438 \u0432\u043A\u043B\u0430\u0434\u043A\u0430\u043C\u0438
      \u0441\u0432\u0435\u0440\u0445\u0443 \u0438 \u0432\u044B\u0431\u0438\u0440\u0430\u0439\u0442\u0435
      \u043A\u0430\u0440\u0442\u043E\u0447\u043A\u0443 \u0441\u043D\u0430\u0431\u0436\u0435\u043D\u0438\u044F
      \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 RecyclerView.\n\n\u0422\u0435\u043A\u0443\u0449\u0435\u0435
      \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0435 \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043E
      \u0434\u043B\u044F \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
      \u0444\u0440\u0435\u0439\u043C\u0432\u043E\u0440\u043A\u0430."
  - EntryId: 82556512
    SectionId: 74957667
    Key: UI.Shop.Category.Item.Description
    Value: "\u0420\u0430\u0441\u0445\u043E\u0434\u043D\u0438\u043A\u0438, \u043A\u043B\u044E\u0447\u0438
      \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
      \u043F\u0440\u0438\u043F\u0430\u0441\u044B \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438
      \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u0432\u043E\u0433\u043E
      \u0446\u0438\u043A\u043B\u0430.\n\n\u0421\u043F\u0438\u0441\u043E\u043A \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0432\u0438\u0440\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E \u043F\u0440\u043E\u043A\u0440\u0443\u0442\u043A\u0443
      RecyclerView \u0438 \u043E\u0431\u043D\u043E\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043F\u0440\u0438 \u0441\u043C\u0435\u043D\u0435 \u0432\u043A\u043B\u0430\u0434\u043E\u043A."
  - EntryId: 80937970
    SectionId: 74957667
    Key: UI.Shop.Category.Skin.Description
    Value: "\u0422\u043E\u0432\u0430\u0440\u044B \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E
      \u0432\u0438\u0434\u0430 \u0438 \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u043E\u0439
      \u0438\u0434\u0435\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430.\n\n\u042D\u0442\u0430
      \u0432\u043A\u043B\u0430\u0434\u043A\u0430 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442
      \u0434\u0440\u0443\u0433\u043E\u0439 \u043D\u0430\u0431\u043E\u0440 \u0434\u0430\u043D\u043D\u044B\u0445
      \u0432 \u0442\u043E\u043C \u0436\u0435 \u0448\u0430\u0431\u043B\u043E\u043D\u0435
      \u0442\u043E\u0432\u0430\u0440\u0430."
