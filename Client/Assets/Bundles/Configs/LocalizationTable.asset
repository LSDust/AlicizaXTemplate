    Key: UI.Home.NoticeTitle
    Value: "\u041E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0437\u0430\u0434\u0430\u043D\u0438\u044F"
  - EntryId: 68864102
    SectionId: 74957667
    Key: UI.Home.NoticeContent
    Value: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430 \u0442\u0435\u0441\u0442\u043E\u0432\u044B\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
      \u044D\u043A\u0440\u0430\u043D. \u041A\u043D\u043E\u043F\u043A\u0438 \u0441\u043F\u0440\u0430\u0432\u0430
      \u0441\u0432\u0435\u0440\u0445\u0443 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442
      \u043C\u0430\u0433\u0430\u0437\u0438\u043D, \u0441\u0443\u043C\u043A\u0443,
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430 \u0438 \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438.\n\n\u042D\u0442\u043E\u0442
      \u044D\u043A\u0440\u0430\u043D \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442
      UI-\u0444\u0440\u0435\u0439\u043C\u0432\u043E\u0440\u043A, \u043F\u0440\u0438\u0432\u044F\u0437\u043A\u0443
      \u043A\u043D\u043E\u043F\u043E\u043A \u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0443\u044E
      \u0430\u043D\u0438\u043C\u0430\u0446\u0438\u044E \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430."
